{
  "name": "@lilian-rpm/open-brain",
  "version": "0.1.0-alpha.2",
  "description": "A local, file-based continuity layer for AI CLI assistants.",
  "keywords": [
    "ai",
    "ai-agents",
    "memory",
    "context",
    "continuity",
    "cli",
    "markdown",
    "vault",
    "knowledge-base",
    "llm"
  ],
  "homepage": "https://github.com/lilianroffi2b-create/open-brain#readme",
  "bugs": {
    "url": "https://github.com/lilianroffi2b-create/open-brain/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lilianroffi2b-create/open-brain.git"
  },
  "author": "Lilian Roffi",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "open-brain": "bin/cli.js"
  },
  "files": [
    "bin/",
    "templates/",
    "integrations/",
    "schemas/",
    "MIGRATIONS/",
    "README.md",
    "LICENSE",
    "BRAND.md",
    "PRIVACY.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "RELEASE_CHECKLIST.md"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:golden": "node scripts/run-golden-tests.mjs",
    "audit:package": "node scripts/audit-package.mjs",
    "build": "tsup --config tsup.config.ts --silent",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run test:golden && npm run audit:package"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
